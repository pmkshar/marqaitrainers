# ──────────────────────────────────────────────────────────
# MarqAI Courses — Environment Configuration
# ──────────────────────────────────────────────────────────
#
# GOLDEN RULE: Demo and Production use SEPARATE databases.
#
#   Local dev  → DATABASE_URL       (SQLite below)
#   Vercel Preview → DEMO_DATABASE_URL     (Vercel Postgres demo DB)
#   Vercel Production → PRODUCTION_DATABASE_URL (Vercel Postgres live DB)
#
# On Vercel, set these in the Dashboard → Settings → Environment Variables:
#   DEMO_DATABASE_URL     → Preview scope only
#   PRODUCTION_DATABASE_URL → Production scope only
#   DATABASE_URL          → (inherits from the correct scoped var above)
# ──────────────────────────────────────────────────────────

# Local development (SQLite)
DATABASE_URL="file:./dev.db"

# These are NOT used locally — they are set per-scope in Vercel Dashboard
# DEMO_DATABASE_URL="postgres://..."
# PRODUCTION_DATABASE_URL="postgres://..."
# v1.0.0 - dual DB setup with golden rule
