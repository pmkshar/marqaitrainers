# ──────────────────────────────────────────────────────────
# MarqAI Courses — Environment Configuration
# ──────────────────────────────────────────────────────────
#
# TWO SEPARATE VERCEL PROJECTS — TWO SEPARATE DATABASES
#
# 1. PRODUCTION (marqaitrainers) → marqaicourses.com
#    DATABASE_URL = neon-bronze-engine (LIVE production DB)
#    Env vars set in Vercel Dashboard (Production scope)
#
# 2. DEMO (marqai-demo) → marqai-demo.vercel.app
#    DATABASE_URL = neon-fulvous-pillow (Demo/preview DB)
#    Env vars set in Vercel Dashboard (all scopes)
#
# Local dev uses SQLite via schema.local.prisma
# ──────────────────────────────────────────────────────────

DATABASE_URL="file:./dev.db"
